# ============================================
# SteadyGains — Environment Variables
# ============================================
# Rename this file to .env and fill in your values:
#   mv env.example .env
#
# Get your Alpaca API keys at:
#   https://app.alpaca.markets/paper/dashboard/overview
#   (Paper trading keys are free — no deposit required)
# ============================================

# Alpaca API Credentials
# Paper trading keys: found at https://app.alpaca.markets/paper/dashboard/overview
# Live trading keys:  found at https://app.alpaca.markets/brokerage/dashboard/overview
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Trading Mode
# 'paper' = simulated trading with fake money (START HERE)
# 'live'  = real money — only switch after paper-testing for 2+ weeks
TRADING_MODE=paper

# Log Level
# 'debug' = everything (very verbose)
# 'info'  = normal operation logs (recommended)
# 'warn'  = only warnings and errors
# 'error' = only errors
LOG_LEVEL=info
